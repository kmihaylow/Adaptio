# Copy to .env (gitignored) and fill in. NEVER commit the real .env.
# The key lives only on the server — the browser never sees it.

# Needed for the AI coach (weekly review + activity analysis)
ANTHROPIC_API_KEY=

# Optional: override the Claude model for coach calls
# ADAPTIO_CLAUDE_MODEL=claude-opus-4-8

# Optional: SQLite location (default: adaptio.db in the working directory).
# intervals.icu / Garmin credentials are per-user and live in the DB, not here.
ADAPTIO_DB_PATH=adaptio.db
